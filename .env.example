PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/guesty_migrate
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:5173
FROM_EMAIL=noreply@guestymigrate.com

# Generate ENCRYPTION_KEY with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

LOG_LEVEL=info

# ── Flat-tier Stripe Price IDs ───────────────────────────────────────────────
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Per-listing graduated pricing (product ID used for price_data) ───────────
STRIPE_PRODUCT_PER_LISTING=prod_...

# ── Add-on Stripe Price IDs ─────────────────────────────────────────────────
STRIPE_PRICE_ADDON_PRIORITY=price_...
STRIPE_PRICE_ADDON_SUPPORT=price_...
STRIPE_PRICE_ADDON_REMIGRATE=price_...
STRIPE_PRICE_ADDON_VERIFY=price_...
