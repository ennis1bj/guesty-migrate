PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/guesty_migrate
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
# ── Redis Configuration ──────────────────────────────────────────────────────
# Redis is OPTIONAL. If unavailable, the app falls back to in-process job execution.
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://username:password@host:port      (Redis 6+ ACL)
# REDIS_URL=redis://:password@host:port               (legacy requirepass)
# REDIS_URL=rediss://...                               (implicit TLS)
# Note: Special characters in passwords must be percent-encoded in the URL.

# Override password from REDIS_URL (useful when password contains special chars)
# REDIS_PASSWORD=

# Override port from REDIS_URL
# REDIS_PORT=6379

# Enable TLS for Redis (set to 'true' if your Redis requires TLS)
# Not needed if you use rediss:// scheme in REDIS_URL
# REDIS_TLS=false

# Accept self-signed TLS certificates (set to 'false' for self-signed certs)
# REDIS_TLS_REJECT_UNAUTHORIZED=true
FRONTEND_URL=http://localhost:5173
FROM_EMAIL=noreply@guestymigrate.com

# Generate ENCRYPTION_KEY with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

LOG_LEVEL=info

# ── PostgreSQL SSL ────────────────────────────────────────────────────────────
# Explicit SSL mode for PostgreSQL (avoids pg v8.11+ deprecation warning).
# Options: 'true' (verify cert), 'no-verify' (TLS without cert verification),
#          'false' (no SSL). If unset, auto-detects from DATABASE_URL sslmode.
# DB_SSL=true

