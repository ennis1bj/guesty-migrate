modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["glib", "nspr", "nss", "atk", "at-spi2-atk", "at-spi2-core", "dbus", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb", "libxkbcommon", "mesa", "alsa-lib", "cups", "libdrm", "wayland"]

[userenv]

[userenv.shared]
FRONTEND_URL = "http://0.0.0.0:5000"
NODE_ENV = "development"
FROM_EMAIL = "noreply@guestymigrate.com"

[userenv.development]
PORT = "3001"

[userenv.production]
PORT = "5000"
# IMPORTANT: Set JWT_SECRET and ENCRYPTION_KEY in Replit Secrets, NOT here.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET = <set in Replit Secrets>
# ENCRYPTION_KEY = <set in Replit Secrets>

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]
