{
  "name": "guesty-migrate",
  "version": "1.0.0",
  "description": "Self-serve migration tool for Guesty property management accounts",
  "private": true,
  "scripts": {
    "postinstall": "cd client && npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npm install && npx vite build",
    "start": "NODE_ENV=production node server/index.js",
    "db:migrate": "node server/db.js migrate"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "bullmq": "^5.1.0",
    "stripe": "^14.11.0",
    "nodemailer": "^6.9.7",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
